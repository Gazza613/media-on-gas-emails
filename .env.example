# ============================================
# MEDIA ON GAS - Environment Variables
# Add these to Vercel Dashboard > Settings > Environment Variables
# ============================================

# --- META (Facebook/Instagram) ---
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_123456789

# --- TIKTOK ---
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_ADVERTISER_ID=your_advertiser_id_here

# --- CLAUDE API ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- GMAIL (for creating drafts) ---
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# --- DRAFT RECIPIENT ---
# All drafts (daily internal + weekly client) go here
DRAFT_EMAIL=gary@gasmarketing.co.za

# --- CAMPAIGN BUDGETS ---
# Format: CAMPAIGNID_COMBINED_BUDGET (underscores, uppercase)
MTN_MOMO_COMBINED_BUDGET=165000
WILLOWBROOK_COMBINED_BUDGET=20000
NEDBANK_COMBINED_BUDGET=0
